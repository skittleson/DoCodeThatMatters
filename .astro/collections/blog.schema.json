{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "modified": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "alt": {
      "type": "string"
    },
    "imageWidth": {
      "type": "number"
    },
    "imageHeight": {
      "type": "number"
    },
    "keywords": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "number"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}