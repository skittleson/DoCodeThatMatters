---
const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#1a2129]">
  <div class="container mx-auto px-4 flex items-center justify-between h-14">
    <a href="/" class="flex items-center gap-2 font-mono text-sm text-[#f5f5f5] hover:text-[#9da2ff] transition-colors">
      <img src="/images/logoWhiteTrans.png" alt="" width="60" height="19" class="mr-1" />
      Do Code That Matters
    </a>
    <ul class="flex gap-6 list-none m-0 p-0">
      <li>
        <a
          href="/blog/"
          class:list={[
            'font-mono text-sm transition-colors',
            currentPath.startsWith('/blog') ? 'text-[#9da2ff]' : 'text-[#f5f5f5] hover:text-[#9da2ff]',
          ]}
        >Blog</a>
      </li>
      <li>
        <a
          href="/about/"
          class:list={[
            'font-mono text-sm transition-colors',
            currentPath.startsWith('/about') ? 'text-[#9da2ff]' : 'text-[#f5f5f5] hover:text-[#9da2ff]',
          ]}
        >About</a>
      </li>
    </ul>
  </div>
</nav>
