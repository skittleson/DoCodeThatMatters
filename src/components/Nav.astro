---
const currentPath = Astro.url.pathname;
---

<nav
  class="fixed top-0 left-0 right-0 z-50"
  style="background-color: var(--color-surface); border-bottom: 1px solid var(--color-border);"
>
  <div class="container mx-auto px-4">

    <!-- Mobile: two rows. Desktop: single row -->
    <div class="md:hidden py-2 flex flex-col gap-1">
      <!-- Row 1: brand -->
      <a
        href="/"
        class="font-mono font-bold text-base leading-tight transition-colors"
        style="color: var(--color-text);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text)'"
      >
        Do Code That Matters
      </a>
      <!-- Row 2: nav links + RSS + theme toggle -->
      <div class="flex items-center gap-4">
        <a
          href="/blog/"
          class="font-mono text-sm transition-colors"
          style={currentPath.startsWith('/blog') ? 'color: var(--color-accent);' : 'color: var(--color-text-muted);'}
        >Blog</a>
        <a
          href="/about/"
          class="font-mono text-sm transition-colors"
          style={currentPath.startsWith('/about') ? 'color: var(--color-accent);' : 'color: var(--color-text-muted);'}
        >About</a>
        <a
          href="/rss.xml"
          aria-label="RSS feed"
          class="transition-colors"
          style="color: var(--color-text-muted);"
          title="RSS feed"
        >
          <!-- RSS icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <circle cx="6.18" cy="17.82" r="2.18"/>
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
          </svg>
        </a>
        <button
          id="theme-toggle"
          aria-label="Toggle light/dark theme"
          class="transition-colors cursor-pointer bg-transparent border-0 p-0"
          style="color: var(--color-text-muted);"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Desktop: single row -->
    <div class="hidden md:flex items-center justify-between h-14">
      <a
        href="/"
        class="font-mono font-bold text-base transition-colors"
        style="color: var(--color-text);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text)'"
      >
        Do Code That Matters
      </a>
      <div class="flex items-center gap-6">
        <a
          href="/blog/"
          class="font-mono text-sm transition-colors"
          style={currentPath.startsWith('/blog') ? 'color: var(--color-accent);' : 'color: var(--color-text-muted);'}
        >Blog</a>
        <a
          href="/about/"
          class="font-mono text-sm transition-colors"
          style={currentPath.startsWith('/about') ? 'color: var(--color-accent);' : 'color: var(--color-text-muted);'}
        >About</a>
        <a
          href="/rss.xml"
          aria-label="RSS feed"
          class="transition-colors"
          style="color: var(--color-text-muted);"
          title="RSS feed"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <circle cx="6.18" cy="17.82" r="2.18"/>
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
          </svg>
        </a>
        <button
          id="theme-toggle-desktop"
          aria-label="Toggle light/dark theme"
          class="transition-colors cursor-pointer bg-transparent border-0 p-0"
          style="color: var(--color-text-muted);"
        >
          <svg id="icon-sun-desktop" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg id="icon-moon-desktop" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</nav>

<script is:inline>
  (function () {
    function syncIcons(theme) {
      var isDark = theme === 'dark';
      // mobile
      var sunM = document.getElementById('icon-sun');
      var moonM = document.getElementById('icon-moon');
      // desktop
      var sunD = document.getElementById('icon-sun-desktop');
      var moonD = document.getElementById('icon-moon-desktop');

      if (sunM) sunM.style.display = isDark ? '' : 'none';
      if (moonM) moonM.style.display = isDark ? 'none' : '';
      if (sunD) sunD.style.display = isDark ? '' : 'none';
      if (moonD) moonD.style.display = isDark ? 'none' : '';
    }

    function toggleTheme() {
      var html = document.documentElement;
      var current = html.dataset.theme || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (_) {}
      syncIcons(next);
    }

    // Sync icons on initial load
    var initialTheme = document.documentElement.dataset.theme || 'dark';
    syncIcons(initialTheme);

    var btn = document.getElementById('theme-toggle');
    var btnD = document.getElementById('theme-toggle-desktop');
    if (btn) btn.addEventListener('click', toggleTheme);
    if (btnD) btnD.addEventListener('click', toggleTheme);
  })();
</script>
