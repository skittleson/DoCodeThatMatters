---
export const prerender = false;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Edit Post</title>
  <style>
    body {
      font-family: monospace;
      background: #1a1a2e;
      color: #e0e0e0;
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    h1 { color: #9da2ff; font-size: 1.5rem; }
    @media (min-width: 640px) { h1 { font-size: 1.75rem; } }
    label { display: block; margin: 0.75rem 0 0.25rem; color: #a0aec0; font-size: 0.85rem; }
    input[type="text"], input[type="number"], input[type="date"], textarea {
      width: 100%;
      padding: 0.5rem;
      background: white;
      color: black;
      border: 1px solid #444;
      border-radius: 4px;
      font-family: monospace;
      box-sizing: border-box;
    }
    textarea {
      min-height: 400px;
      resize: vertical;
      background: white;
      color: black;
    }
    button {
      padding: 0.75rem 1.5rem;
      background: #9da2ff;
      color: #1a1a2e;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-family: monospace;
      font-weight: bold;
      font-size: 1rem;
      margin-top: 1rem;
    }
    button:hover { background: #7b82ff; }
    .error { color: #ff6b6b; }
    .success { color: #51cf66; }
    .form-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .form-row > div { flex: 1; min-width: 0; }
    .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }

    /* Restored-draft banner */
    .draft-banner {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
      padding: 0.6rem 0.9rem;
      background: rgba(157, 162, 255, 0.15);
      border: 1px solid #9da2ff;
      border-left: 4px solid #9da2ff;
      border-radius: 4px;
      color: #e0e0e0;
      font-size: 0.9rem;
    }
    /* .draft-banner sets display:flex, which out-specifies the UA [hidden]
       rule, so restore display:none explicitly when hidden. */
    .draft-banner[hidden] { display: none; }
    .draft-banner .draft-banner-msg { flex: 1; min-width: 12rem; }
    .draft-banner button {
      margin-top: 0;
      padding: 0.4rem 0.9rem;
      font-size: 0.85rem;
    }

    /* Back-to-list link — prominent on mobile */
    .back-link {
      display: inline-block;
      padding: 0.75rem 1rem;
      margin-bottom: 0.5rem;
      color: #9da2ff;
      font-size: 1rem;
      font-weight: bold;
      text-decoration: none;
      border: 2px solid #9da2ff;
      border-radius: 4px;
    }
    .back-link:hover { background: #9da2ff; color: #1a1a2e; }

    /* Post Metadata summary — larger tap target */
    details > summary {
      padding: 0.75rem 1rem;
      cursor: pointer;
      font-size: 1rem;
      font-weight: bold;
      color: #9da2ff;
      background: rgba(157, 162, 255, 0.1);
      border: 1px solid #444;
      border-radius: 4px;
      list-style: none;
      display: flex;
      align-items: center;
    }
    details > summary::before {
      content: '▸';
      margin-right: 0.5rem;
      transition: transform 0.15s;
    }
    details[open] > summary::before {
      transform: rotate(90deg);
    }
    details > summary::-webkit-details-marker { display: none; }

    /* EasyMDE rich markdown editor overrides */
    /* Editing area: white background, black text (per user preference) */
    .EasyMDEContainer .CodeMirror {
      background: #ffffff;
      color: #000000;
      border: 1px solid #444;
      border-bottom-left-radius: 4px;
      border-bottom-right-radius: 4px;
      font-family: monospace;
      min-height: 400px;
    }
    .EasyMDEContainer .CodeMirror-cursor { border-color: #000000; }
    .EasyMDEContainer .CodeMirror-selected { background: #d7d4f0; }
    .EasyMDEContainer .cm-s-easymde .CodeMirror-selected { background: #d7d4f0; }

    /* Toolbar: no custom styling — use EasyMDE's default light appearance */

    /* Preview / side-by-side panes: white background, black text */
    .EasyMDEContainer .editor-preview,
    .EasyMDEContainer .editor-preview-side {
      background: #ffffff;
      color: #000000;
      font-family: system-ui, sans-serif;
      line-height: 1.6;
    }
    .EasyMDEContainer .editor-preview-side {
      border: 1px solid #444;
    }
    .EasyMDEContainer .editor-preview a,
    .EasyMDEContainer .editor-preview-side a { color: #3182ce; }
    .EasyMDEContainer .editor-preview pre,
    .EasyMDEContainer .editor-preview-side pre {
      background: #1a202c;
      color: #e2e8f0;
      padding: 0.75rem 1rem;
      border-radius: 6px;
      overflow-x: auto;
    }
    .EasyMDEContainer .editor-preview code,
    .EasyMDEContainer .editor-preview-side code {
      background: #edf2f7;
      color: #c53030;
      padding: 0.15em 0.3em;
      border-radius: 3px;
    }
    .EasyMDEContainer .editor-preview pre code,
    .EasyMDEContainer .editor-preview-side pre code {
      background: none;
      color: #e2e8f0;
      padding: 0;
    }
    .EasyMDEContainer .editor-preview blockquote,
    .EasyMDEContainer .editor-preview-side blockquote {
      border-left: 4px solid #9da2ff;
      background: #f7fafc;
      color: #4a5568;
      margin: 0.75rem 0;
      padding: 0.5rem 1rem;
    }
    .EasyMDEContainer .editor-preview img,
    .EasyMDEContainer .editor-preview-side img { max-width: 100%; }

    /* Mobile responsiveness — allow toolbar to wrap, shrink fullscreen */
    @media (max-width: 640px) {
      .EasyMDEContainer .editor-toolbar {
        flex-wrap: wrap;
      }
      .EasyMDEContainer .CodeMirror { min-height: 300px; }
    }
  </style>
</head>
<body>
  <h1>Edit Post</h1>
  <a href="/admin/" class="back-link">← Back to list</a>

  <form id="post-form">
    <div id="draft-banner" class="draft-banner" role="status" aria-live="polite" hidden>
      <span class="draft-banner-msg" id="draft-banner-msg"></span>
      <button type="button" id="discard-draft-btn">Discard draft</button>
    </div>

    <details>
      <summary>Edit Metadata</summary>

      <label for="title">Title *</label>
      <input type="text" id="title" required minlength="5" maxlength="100" placeholder="Post title" />

      <label for="description">Description</label>
      <input type="text" id="description" placeholder="Short summary" />

      <div class="form-row">
        <div>
          <label for="date">Date</label>
          <input type="date" id="date" />
        </div>
        <div>
          <label for="modified">Modified</label>
          <input type="date" id="modified" />
        </div>
      </div>

      <label for="image">Image path</label>
      <input type="text" id="image" placeholder="/images/my-image.png" />

      <label for="alt">Alt text</label>
      <input type="text" id="alt" />

      <div class="form-row">
        <div>
          <label for="imageWidth">Image width</label>
          <input type="number" id="imageWidth" min="0" />
        </div>
        <div>
          <label for="imageHeight">Image height</label>
          <input type="number" id="imageHeight" min="0" />
        </div>
      </div>

      <label for="keywords">Keywords (comma-separated)</label>
      <input type="text" id="keywords" placeholder="keyword1, keyword2" />

      <label for="priority">Priority (0-1)</label>
      <input type="number" id="priority" min="0" max="1" step="0.1" />

      <label>
        <input type="checkbox" id="draft" />
        Draft (not published)
      </label>

    </details>

    <label for="body">Markdown body — use the toolbar to format, toggle preview for a live render</label>
    <textarea id="body" placeholder="# Your post content here"></textarea>

    <div class="btn-row">
      <button type="submit">Save</button>
      <button type="button" id="cancel-btn">Cancel</button>
    </div>
    <div id="status"></div>
  </form>

  <script>
    import { getToken } from '/src/lib/tokenStore.ts';
    import { getBlogPosts, createOrUpdatePost } from '/src/lib/githubClient.ts';
    import { assemblePost } from '/src/lib/assembler.ts';
    import { saveDraft, loadDraft, clearDraft, formatRelativeTime } from '/src/lib/editHelpers.ts';
    import EasyMDE from 'easymde';
    import 'easymde/dist/easymde.min.css';

    const form = document.getElementById('post-form');
    const statusEl = document.getElementById('status');
    const bodyTextarea = document.getElementById('body');
    const cancelBtn = document.getElementById('cancel-btn');
    const draftBanner = document.getElementById('draft-banner');
    const draftBannerMsg = document.getElementById('draft-banner-msg');
    const discardDraftBtn = document.getElementById('discard-draft-btn');

    // Slug that keys this post's draft in localStorage. An empty `slug` query
    // param means "new post", which the draft helpers bucket under "new".
    const params = new URLSearchParams(window.location.search);
    const editSlug = params.get('slug') || '';
    const currentSlug = editSlug;

    // Initialize the rich markdown editor on the #body textarea.
    // EasyMDE builds its own toolbar + live/side-by-side preview and
    // bundles its own markdown rendering, so no separate preview pane needed.
    const easyMDE = new EasyMDE({
      element: bodyTextarea,
      spellChecker: false,
      autoDownloadFontAwesome: true,
      placeholder: '# Your post content here',
      status: ['lines', 'words', 'cursor'],
      toolbar: [
        'bold', 'italic', 'heading', '|',
        'quote', 'unordered-list', 'ordered-list', '|',
        'link', 'image', 'code', 'table', 'horizontal-rule', '|',
        'preview', 'side-by-side', 'fullscreen', '|',
        'guide',
      ],
    });

    // Track original field values to detect dirty form
    const originalValues = new Map();

    // Metadata fields tracked via their DOM elements. The `body` field is
    // tracked separately through the EasyMDE instance (easyMDE.value()).
    const trackedFields = [
      { id: 'title', type: 'text' },
      { id: 'description', type: 'text' },
      { id: 'date', type: 'text' },
      { id: 'modified', type: 'text' },
      { id: 'image', type: 'text' },
      { id: 'alt', type: 'text' },
      { id: 'imageWidth', type: 'text' },
      { id: 'imageHeight', type: 'text' },
      { id: 'keywords', type: 'text' },
      { id: 'priority', type: 'text' },
      { id: 'draft', type: 'checkbox' },
    ];

    function captureOriginalValues() {
      for (const f of trackedFields) {
        const el = document.getElementById(f.id);
        if (!el) continue;
        if (f.type === 'checkbox') {
          originalValues.set(f.id, (el as HTMLInputElement).checked);
        } else {
          originalValues.set(f.id, (el as HTMLInputElement | HTMLTextAreaElement).value);
        }
      }
      // Body value comes from the editor instance, not the raw textarea.
      originalValues.set('body', easyMDE.value());
    }

    function isFormDirty(): boolean {
      for (const f of trackedFields) {
        const el = document.getElementById(f.id);
        if (!el) continue;
        let current;
        if (f.type === 'checkbox') {
          current = (el as HTMLInputElement).checked;
        } else {
          current = (el as HTMLInputElement | HTMLTextAreaElement).value;
        }
        if (current !== originalValues.get(f.id)) return true;
      }
      if (easyMDE.value() !== originalValues.get('body')) return true;
      return false;
    }

    // --- Draft auto-save (localStorage) -------------------------------------

    // Snapshot the current form state for a draft: every tracked metadata
    // field plus the editor body (mirrors captureOriginalValues + body).
    function collectDraftData() {
      const data: Record<string, unknown> = {};
      for (const f of trackedFields) {
        const el = document.getElementById(f.id);
        if (!el) continue;
        if (f.type === 'checkbox') {
          data[f.id] = (el as HTMLInputElement).checked;
        } else {
          data[f.id] = (el as HTMLInputElement | HTMLTextAreaElement).value;
        }
      }
      data.body = easyMDE.value();
      return data;
    }

    // Apply a stored draft back onto the form + editor.
    function applyDraftData(data: Record<string, unknown>) {
      for (const f of trackedFields) {
        if (!(f.id in data)) continue;
        const el = document.getElementById(f.id);
        if (!el) continue;
        if (f.type === 'checkbox') {
          (el as HTMLInputElement).checked = Boolean(data[f.id]);
        } else {
          const v = data[f.id];
          (el as HTMLInputElement | HTMLTextAreaElement).value = v == null ? '' : String(v);
        }
      }
      if (typeof data.body === 'string') easyMDE.value(data.body);
    }

    function showDraftBanner(savedAt: string) {
      draftBannerMsg.textContent = `Restored unsaved draft from ${formatRelativeTime(savedAt)}.`;
      draftBanner.hidden = false;
    }

    // Restore a draft on top of the freshly pre-filled server values, if one
    // exists. captureOriginalValues() must run first so the layered draft
    // registers as a dirty change against the server baseline.
    function maybeRestoreDraft() {
      const draft = loadDraft(currentSlug);
      if (!draft) return;
      applyDraftData(draft);
      showDraftBanner(draft.savedAt);
    }

    let saveTimer: ReturnType<typeof setTimeout>;
    function scheduleSave() {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(() => saveDraft(currentSlug, collectDraftData()), 500);
    }

    // Wire debounced auto-save to the editor + each tracked metadata field.
    // Called AFTER prefill/restore so programmatic value-setting during load
    // does not spuriously create a draft.
    function attachAutoSave() {
      easyMDE.codemirror.on('change', scheduleSave);
      for (const f of trackedFields) {
        const el = document.getElementById(f.id);
        if (!el) continue;
        el.addEventListener('input', scheduleSave);
        if (f.type === 'checkbox') el.addEventListener('change', scheduleSave);
      }
    }

    // Discard the draft and reload the pristine server version. A full reload
    // re-fetches + re-pre-fills the fields and, with the draft now cleared,
    // skips the restore step (no banner).
    discardDraftBtn.addEventListener('click', () => {
      clearDraft(currentSlug);
      draftBanner.hidden = true;
      window.location.reload();
    });

    function navigateAway() {
      if (!isFormDirty()) {
        clearDraft(currentSlug);
        window.location.href = '/admin/';
        return;
      }
      if (confirm('Discard changes?')) {
        clearDraft(currentSlug);
        window.location.href = '/admin/';
      }
    }

    // Validate title length
    const titleInput = document.getElementById('title');
    titleInput.addEventListener('input', () => {
      if (titleInput.value.length < 5) {
        titleInput.setCustomValidity('Title must be at least 5 characters');
      } else {
        titleInput.setCustomValidity('');
      }
    });

    // Fetch the post from GitHub and pre-fill the editor + metadata fields
    // with the server version. (Keywords are intentionally left alone — they
    // are a multi-line YAML array the simple line parser can't restore.)
    async function prefillFromServer(token) {
      const posts = await getBlogPosts(token);
      const post = posts.find(p => p.name === `${editSlug}.md`);
      if (!post) return;
      const raw = await fetch(post.download_url).then(r => r.text());
      const match = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
      if (!match) return;
      const yamlText = match[1];
      const body = match[2];
      easyMDE.value(body);
      const lines = yamlText.split('\n');
      for (const line of lines) {
        const [key, ...rest] = line.split(':');
        const value = rest.join(':').trim();
        const input = document.getElementById(key.trim());
        if (input && key.trim() !== 'keywords') {
          if (key.trim() === 'draft') {
            (input as HTMLInputElement).checked = value === 'true';
          } else {
            (input as HTMLInputElement).value = value;
          }
        }
      }
    }

    // On page load, check auth and pre-fill form if editing.
    const token = getToken();
    if (!token) {
      window.location.href = '/admin/';
    } else {
      (async () => {
        if (editSlug) {
          try {
            await prefillFromServer(token);
          } catch (err) {
            statusEl.textContent = `Failed to load post: ${err.message}`;
            statusEl.className = 'error';
          }
        }
        // Baseline = server version (or an empty form for a new post). Capture
        // BEFORE restoring so a restored draft reads as dirty; then layer any
        // saved draft on top and wire auto-save last.
        captureOriginalValues();
        maybeRestoreDraft();
        attachAutoSave();
      })();
    }

    cancelBtn.addEventListener('click', navigateAway);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const token = getToken();
      if (!token) {
        statusEl.textContent = 'Not authenticated. Please log in first.';
        statusEl.className = 'error';
        return;
      }

      const title = titleInput.value.trim();
      const slug = title
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/-+$/, '')
        .replace(/^-+/, '');

      // Always set modified to today's date before saving
      document.getElementById('modified').value = new Date().toISOString().split('T')[0];

      const data = {
        title,
        description: document.getElementById('description').value.trim() || undefined,
        date: document.getElementById('date').value || undefined,
        modified: document.getElementById('modified').value || undefined,
        image: document.getElementById('image').value.trim() || undefined,
        alt: document.getElementById('alt').value.trim() || undefined,
        imageWidth: document.getElementById('imageWidth').value ? parseInt(document.getElementById('imageWidth').value) : undefined,
        imageHeight: document.getElementById('imageHeight').value ? parseInt(document.getElementById('imageHeight').value) : undefined,
        keywords: document.getElementById('keywords').value ? document.getElementById('keywords').value.split(',').map(s => s.trim()).filter(Boolean) : undefined,
        priority: document.getElementById('priority').value ? parseFloat(document.getElementById('priority').value) : undefined,
        draft: document.getElementById('draft').checked,
        body: easyMDE.value(),
      };

      const content = assemblePost(data);
      const message = `blog: update ${title}`;

      // Look up existing SHA so edits don't conflict
      try {
        const posts = await getBlogPosts(token);
        const existingPost = posts.find(p => p.name === `${slug}.md`);
        const existingSha = existingPost?.sha;

        statusEl.textContent = 'Saving...';
        statusEl.className = '';

        await createOrUpdatePost(token, slug, content, message, existingSha);
        // Persisted to GitHub — discard the local draft before redirecting.
        clearDraft(currentSlug);
        statusEl.textContent = `Saved! Post available at /${slug}/`;
        statusEl.className = 'success';
        setTimeout(() => { window.location.href = '/admin/'; }, 2000);
      } catch (err) {
        statusEl.textContent = `Error: ${err.message}`;
        statusEl.className = 'error';
      }
    });
  </script>
</body>
</html>
