---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, modified, image, alt, keywords } = post.data;

const siteUrl = 'https://docodethatmatters.com';
const postUrl = new URL(`/${post.slug}/`, siteUrl).href;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const schemaDate = (d: Date) => d.toISOString();

// Fetch latest 5 published posts for the sidebar
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0))
  .slice(0, 5);

const issueTitle = encodeURIComponent(`Post - ${title}`);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  keywords={keywords}
  canonicalUrl={postUrl}
>
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <div class="lg:grid lg:grid-cols-4 lg:gap-8">
      <!-- Main Article -->
      <div class="lg:col-span-3">
        <article
          class="article-body"
          itemprop="blogPost"
          itemscope
          itemtype="http://schema.org/BlogPosting"
        >
          <meta itemprop="mainEntityOfPage" content={postUrl} />

          <header class="mb-6">
            <h1 itemprop="name headline" class="text-2xl font-bold text-[#f5f5f5] mb-3">
              {title}
            </h1>
            <p class="text-sm text-[#a0aec0] font-mono mb-4">
              {date && (
                <time itemprop="datePublished" datetime={schemaDate(date)}>
                  {formatDate(date)}
                </time>
              )}
              {modified && (
                <meta itemprop="dateModified" content={schemaDate(modified)} />
              )}
              {' '}by{' '}
              <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                <a
                  rel="author"
                  itemprop="url"
                  href={`${siteUrl}/about/`}
                  class="text-[#9da2ff] hover:underline"
                >
                  <span itemprop="name">Spencer Kittleson</span>
                </a>
                <meta itemprop="jobTitle" content="Software Engineer" />
              </span>
              <span itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
                <meta itemprop="name" content="Do Code That Matters" />
                <span itemprop="logo" itemscope itemtype="https://schema.org/ImageObject">
                  <meta itemprop="url" content={`${siteUrl}/images/agile.jpg`} />
                </span>
              </span>
            </p>

            {image && (
              <figure itemprop="image" itemscope itemtype="https://schema.org/ImageObject" class="mb-6">
                <img
                  itemprop="url contentUrl"
                  src={image}
                  alt={alt ?? title}
                  class="rounded-md w-full object-cover"
                  loading="lazy"
                />
                {alt && (
                  <figcaption itemprop="caption" class="text-xs text-[#a0aec0] mt-1 text-center">
                    {alt}
                  </figcaption>
                )}
              </figure>
            )}
          </header>

          <section itemprop="articleBody" class="prose prose-invert max-w-none">
            <slot />
          </section>
        </article>

        <hr class="my-8" />

        <p class="text-sm font-mono text-[#a0aec0]">
          See something inaccurate or need more detail?{' '}
          <a
            href={`https://github.com/skittleson/DoCodeThatMatters/issues/new?title=${issueTitle}`}
            class="text-[#9da2ff] hover:underline"
          >
            Submit a Pull Request
          </a>{' '}
          to help me out!
        </p>
        <p class="text-sm font-mono text-[#a0aec0] mt-2">
          <a href="https://www.buymeacoffee.com/skittles" class="text-[#9da2ff] hover:underline">
            Buy me a ☕ to support!
          </a>
        </p>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block lg:col-span-1 mt-8 lg:mt-0">
        <h3 class="text-sm font-bold text-[#f5f5f5] font-mono mb-3 uppercase tracking-wide">
          Latest Posts
        </h3>
        <ul class="space-y-2 list-none p-0 m-0">
          {latestPosts.map((p) => (
            <li>
              <a
                href={`/${p.slug}/`}
                class="text-xs text-[#9da2ff] hover:underline font-mono leading-snug block"
              >
                {p.data.title}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </main>
</BaseLayout>
