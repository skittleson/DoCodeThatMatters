---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, modified, image, alt, imageWidth, imageHeight, keywords } = post.data;

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const postUrl = new URL(`/${post.slug}/`, Astro.site).href;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

const schemaDate = (d: Date) => d.toISOString();

// Reading time: ~200 words per minute
const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Fetch latest 5 published posts for the sidebar
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0))
  .slice(0, 5);

const issueTitle = encodeURIComponent(`Post - ${title}`);

// Responsive image helpers
const isLocalImage = image && image.startsWith('/images/');
const isRemoteImage = image && image.startsWith('http');

// For local images: derive a 760w variant path (e.g. /images/foo.jpg → /images/foo-760w.jpg)
const localSrcset = isLocalImage
  ? (() => {
      const dot = image.lastIndexOf('.');
      const base = image.slice(0, dot);
      const ext = image.slice(dot);
      return `${base}-760w${ext} 760w, ${image} 1200w`;
    })()
  : null;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  keywords={keywords}
  canonicalUrl={postUrl}
>
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <div class="lg:grid lg:grid-cols-4 lg:gap-8">
      <!-- Main Article -->
      <div class="lg:col-span-3">
        <article
          class="article-body"
          itemprop="blogPost"
          itemscope
          itemtype="http://schema.org/BlogPosting"
        >
          <meta itemprop="mainEntityOfPage" content={postUrl} />

          <header class="mb-6">
            <h1 itemprop="name headline" class="text-2xl font-bold mb-3" style="color: var(--color-text);">
              {title}
            </h1>

            <!-- Metadata: date · reading time · author -->
            <p class="text-xs font-mono mb-4 flex flex-wrap items-center gap-x-2 gap-y-1" style="color: var(--color-text-muted);">
              {date && (
                <>
                  <time itemprop="datePublished" datetime={schemaDate(date)}>
                    {formatDate(date)}
                  </time>
                  <span aria-hidden="true">·</span>
                </>
              )}
              {modified && (
                <meta itemprop="dateModified" content={schemaDate(modified)} />
              )}
              <span>{readingTime} min read</span>
              <span aria-hidden="true">·</span>
              <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                <a
                  rel="author"
                  itemprop="url"
                  href={`${siteUrl}/about/`}
                  style="color: var(--color-accent);"
                  class="hover:underline"
                >
                  <span itemprop="name">Spencer Kittleson</span>
                </a>
                <meta itemprop="jobTitle" content="Software Engineer" />
              </span>
              <span itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
                <meta itemprop="name" content="Do Code That Matters" />
                <span itemprop="logo" itemscope itemtype="https://schema.org/ImageObject">
                  <meta itemprop="url" content={`${siteUrl}/images/agile.jpg`} />
                </span>
              </span>
            </p>

            {image && (
              <figure itemprop="image" itemscope itemtype="https://schema.org/ImageObject" class="mb-6">
                {isLocalImage ? (
                  <img
                    itemprop="url contentUrl"
                    src={image}
                    srcset={localSrcset ?? undefined}
                    sizes="(max-width: 768px) calc(100vw - 2rem), 570px"
                    alt={alt ?? title}
                    width={imageWidth ?? 800}
                    height={imageHeight ?? 600}
                    class="rounded-md w-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                ) : (
                  <img
                    itemprop="url contentUrl"
                    src={image}
                    alt={alt ?? title}
                    width={imageWidth ?? 800}
                    height={imageHeight ?? 600}
                    class="rounded-md w-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                  />
                )}
                {alt && (
                  <figcaption itemprop="caption" class="text-xs mt-1 text-center" style="color: var(--color-text-muted);">
                    {alt}
                  </figcaption>
                )}
              </figure>
            )}
          </header>

          <section itemprop="articleBody" class="prose prose-invert max-w-none">
            <slot />
          </section>
        </article>

        <hr class="my-8" />

        <p class="text-sm font-mono" style="color: var(--color-text-muted);">
          See something inaccurate or need more detail?{' '}
          <a
            href={`https://github.com/skittleson/DoCodeThatMatters/issues/new?title=${issueTitle}`}
            style="color: var(--color-accent);"
            class="underline"
          >
            Submit a Pull Request
          </a>{' '}
          to help me out!
        </p>
        <p class="text-sm font-mono mt-2">
          <a href="https://www.buymeacoffee.com/skittles" style="color: var(--color-accent);" class="hover:underline">
            Buy me a ☕ to support!
          </a>
        </p>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block lg:col-span-1 mt-8 lg:mt-0">
        <h3 class="text-xs font-bold font-mono mb-3 uppercase tracking-wide" style="color: var(--color-text);">
          Latest Posts
        </h3>
        <ul class="space-y-3 list-none p-0 m-0">
          {latestPosts.map((p) => (
            <li>
              <a
                href={`/${p.slug}/`}
                class="text-xs font-mono leading-snug block hover:underline"
                style="color: var(--color-accent);"
              >
                {p.data.title}
              </a>
              {p.data.date && (
                <time
                  datetime={p.data.date.toISOString()}
                  class="text-xs font-mono block mt-0.5"
                  style="color: var(--color-text-muted);"
                >
                  {formatDate(p.data.date)}
                </time>
              )}
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </main>
</BaseLayout>
